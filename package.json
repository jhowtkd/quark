{
  "name": "futuria",
  "version": "0.1.0",
  "description": "FUTUR.IA - Swarm Intelligence Engine for Social Simulation",
  "scripts": {
    "setup": "npm install && cd frontend && npm install",
    "setup:backend": "cd backend && uv sync",
    "setup:all": "npm run setup && npm run setup:backend",
    "dev": "concurrently --kill-others -n \"backend,frontend\" -c \"green,cyan\" \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && uv run python run.py",
    "frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "check:language-reporting": "python3 scripts/check_language_contamination.py --scope reporting --fail-on-policy-breach",
    "check:language-backend": "python3 scripts/check_language_contamination.py --scope reporting-backend --fail-on-policy-breach",
    "check:language-artifacts": "python3 scripts/normalize_report_artifacts.py --scope reporting --dry-run --fail-on-contamination",
    "preflight": "npm run check:language-backend && npm run check:language-artifacts",
    "remediate:report-artifacts": "python3 scripts/normalize_report_artifacts.py --scope reporting --dry-run",
    "remediate:report-artifacts:fix": "python3 scripts/normalize_report_artifacts.py --scope reporting --normalize --quarantine",
    "scan:secrets": "python3 scripts/scan_secrets.py"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "convex": "^1.35.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "AGPL-3.0"
}
